<script>
  // Handling the impressum modal
  const impressumModal = document.getElementById("impressum-modal");
  const openImpressum = document.getElementById("open-impressum");
  const closeImpressumModal = document.getElementById("close-impressum-modal");

  openImpressum.addEventListener("click", () => {
    impressumModal.classList.remove("hidden");
  });

  closeImpressumModal.addEventListener("click", () => {
    impressumModal.classList.add("hidden");
  });

  // Close modal if clicking outside of it
  impressumModal.addEventListener("click", (e) => {
    if (e.target === impressumModal) {
      impressumModal.classList.add("hidden");
    }
  });
</script>
